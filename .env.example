# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api

# Public (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (NEVER expose to client - no NEXT_PUBLIC_ prefix)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LiveKit (used by Next.js app and the AI reviewer agent)
LIVEKIT_URL=wss://host.docker.internal:7880
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# -----------------------------------------------------------------------------
# AI Game Reviewer agent (feature 022)
# Only needed if you run the `agent` docker service.
# -----------------------------------------------------------------------------

# Azure Speech-to-Text — Persian transcription
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_LANGUAGE=fa-IR

# Google Vertex AI (Gemini) — summarization
GCP_PROJECT_ID=your-gcp-project-id
GCP_VERTEX_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-pro
# Mount the service-account JSON into the container and point here:
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/vertex-sa.json

# Optional overrides
# DATA_DIR=/data/games
# PROMPTS_DIR=./prompts
# LIVEKIT_BOT_IDENTITY_PREFIX=reviewer-
# GAME_WATCHER_INTERVAL_MS=3000
# AUDIO_SAMPLE_RATE=16000
# SILENCE_RMS_THRESHOLD=250
# RETRY_MAX_ATTEMPTS=3
# RETRY_BASE_DELAY_MS=500
